{
  "version": 6,
  "include": [
    "build/Debug/generators/CMakePresets.json",
    "build/Release/generators/CMakePresets.json"
  ],
  "configurePresets": [
    {
      "name": "debug",
      "inherits": "conan-debug"
    },
    {
      "name": "release",
      "inherits": "conan-release"
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}